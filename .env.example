# =============================================
# Jouri Hakuraku — Environment Variables Template
# =============================================
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
# =============================================

# --- System Authentication ---
LOGIN_CODE=""
APP_AUTH_KEY=""       # Nginx access password; leave empty to disable BasicAuth (set this in production)
TRACKING_TOPIC=""

# --- LLM Configuration ---
LLM_PROVIDER="google"                  # Options: google / anthropic / openai
OPENAI_API_KEY=""                      # OpenAI API Key
ANTHROPIC_API_KEY=""                   # Anthropic API Key
GOOGLE_API_KEY=""                      # Google AI Studio API Key (required when LLM_PROVIDER=google)
GEMINI_MODEL="gemini-3.1-flash-lite-preview"

# --- Daily Rollup LLM Configuration (separate from main LLM) ---
DAILY_ROLLUP_LLM_PROVIDER="openai"    # Options: google / anthropic / openai
DAILY_ROLLUP_OPENAI_MODEL="gpt-5.4-2026-03-05"
DAILY_ROLLUP_ANTHROPIC_MODEL="claude-3-5-sonnet-20240620"
DAILY_ROLLUP_GEMINI_MODEL="gemini-3.1-flash-lite-preview"

# --- Discord Self-Bot Configuration ---
DISCORD_USER_TOKEN=""                   # Discord User Token (required)
DISCORD_CHANNEL_IDS=""                 # Comma-separated channel IDs to listen to; leave empty to listen to all
TRUSTED_CHANNEL_IDS=""                 # Whitelisted channel IDs; messages from these bypass AI and go straight to DB
